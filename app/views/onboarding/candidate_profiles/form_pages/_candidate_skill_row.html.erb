<div class="mb-3 flex items-start gap-3" data-nested-fields-target="row">
  <%= f.hidden_field :id %>
  <%= f.hidden_field :_destroy %>

  <div class="flex-1">
    <%= f.select :skill_id, skills.map { |skill| [ skill.name, skill.id ] }, { include_blank: "Choose a skill" }, class: form_input_class %>
  </div>

  <div class="flex-1">
    <%= f.text_field :suggested_name, placeholder: "Not listed? Type it here", class: form_input_class %>
  </div>

  <button type="button" data-action="nested-fields#remove" class="mt-2 text-sm font-medium text-red-600 hover:text-red-500">
    Remove
  </button>
</div>
