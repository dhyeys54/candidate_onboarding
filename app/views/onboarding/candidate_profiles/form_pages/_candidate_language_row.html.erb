<div class="mb-3 flex items-start gap-3" data-nested-fields-target="row">
  <%= f.hidden_field :id %>
  <%= f.hidden_field :_destroy %>

  <div class="flex-1">
    <%= f.select :language_id, languages.map { |language| [ language.name, language.id ] }, { include_blank: "Choose a language" }, class: form_input_class %>
  </div>

  <div class="flex-1">
    <%= f.select :proficiency,
          Onboarding::CandidateLanguage.proficiencies.keys.map { |key| [ key.humanize, key ] },
          { include_blank: true }, class: form_input_class %>
  </div>

  <button type="button" data-action="nested-fields#remove" class="mt-2 text-sm font-medium text-red-600 hover:text-red-500">
    Remove
  </button>
</div>
