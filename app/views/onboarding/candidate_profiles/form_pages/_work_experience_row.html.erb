<div class="mb-4 rounded-lg border border-gray-200 p-4" data-nested-fields-target="row">
  <%= f.hidden_field :id %>
  <%= f.hidden_field :_destroy %>

  <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
    <div>
      <%= f.label :job_title, class: form_label_class %>
      <%= f.text_field :job_title, class: form_input_class %>
    </div>

    <div>
      <%= f.label :company_name, class: form_label_class %>
      <%= f.text_field :company_name, class: form_input_class %>
    </div>

    <div>
      <%= f.label :start_date, class: form_label_class %>
      <%= f.date_field :start_date, class: form_input_class %>
    </div>

    <div>
      <%= f.label :end_date, class: form_label_class %>
      <%= f.date_field :end_date, class: form_input_class %>
    </div>

    <div class="flex items-center gap-2 sm:col-span-2">
      <%= f.check_box :current_job, class: "rounded border-gray-300" %>
      <%= f.label :current_job, "I currently work here", class: "text-sm text-gray-700" %>
    </div>

    <div class="sm:col-span-2">
      <%= f.label :responsibilities, class: form_label_class %>
      <%= f.text_area :responsibilities, rows: 3, class: form_input_class %>
    </div>
  </div>

  <button type="button" data-action="nested-fields#remove" class="mt-3 text-sm font-medium text-red-600 hover:text-red-500">
    Remove
  </button>
</div>
