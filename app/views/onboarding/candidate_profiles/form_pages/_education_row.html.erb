<div class="mb-4 rounded-lg border border-gray-200 p-4" data-nested-fields-target="row">
  <%= f.hidden_field :id %>
  <%= f.hidden_field :_destroy %>

  <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
    <div>
      <%= f.label :institution, class: form_label_class %>
      <%= f.text_field :institution, class: form_input_class %>
    </div>

    <div>
      <%= f.label :study, "Study / course", class: form_label_class %>
      <%= f.text_field :study, class: form_input_class(f.object, :study) %>
      <%= field_errors(f.object, :study) %>
    </div>

    <div>
      <%= f.label :location, "City and country", class: form_label_class %>
      <%= f.text_field :location, class: form_input_class %>
    </div>

    <div>
      <%= f.label :level, class: form_label_class %>
      <%= f.select :level,
            Onboarding::Education.levels.keys.map { |key| [ Onboarding::Education::LEVEL_LABELS.fetch(key, key.humanize), key ] },
            { include_blank: true }, class: form_input_class %>
    </div>

    <div>
      <%= f.label :start_date, class: form_label_class %>
      <%= f.date_field :start_date, class: form_input_class %>
    </div>

    <div>
      <%= f.label :end_date, class: form_label_class %>
      <%= f.date_field :end_date, class: form_input_class %>
    </div>
  </div>

  <button type="button" data-action="nested-fields#remove" class="mt-3 text-sm font-medium text-red-600 hover:text-red-500">
    Remove
  </button>
</div>
