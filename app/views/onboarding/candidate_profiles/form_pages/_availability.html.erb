<div class="grid grid-cols-1 gap-6">
  <div>
    <%= checkbox_group(candidate_profile, :working_days, options: Onboarding::CandidateProfile::WORKING_DAYS,
          label: "Available working days", grid_class: "grid-cols-2 sm:grid-cols-4", required: true) %>
  </div>

  <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
    <div>
      <%= field_label(form, :available_from, candidate_profile: candidate_profile, required: true) %>
      <%= form.date_field :available_from, class: form_input_class(candidate_profile, :available_from) %>
      <%= field_errors(candidate_profile, :available_from) %>
    </div>

    <div>
      <%= form.label :notice_period, class: form_label_class %>
      <%= form.text_field :notice_period, class: form_input_class %>
    </div>
  </div>
</div>
