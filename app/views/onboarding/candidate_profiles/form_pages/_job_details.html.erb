<div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
  <div>
    <%= field_label(form, :job_function, text: "Desired job function", candidate_profile: candidate_profile, required: true) %>
    <%= form.select :job_function,
          Onboarding::CandidateProfile.job_functions.keys.map { |key| [ key.humanize, key ] },
          { include_blank: true }, class: form_input_class(candidate_profile, :job_function) %>
    <%= field_errors(candidate_profile, :job_function) %>
  </div>
</div>

<h3 class="mt-8 text-base font-semibold text-gray-900">Job preferences</h3>
<div class="mt-4 grid grid-cols-1 gap-4 sm:grid-cols-2">
  <div class="sm:col-span-2">
    <%= checkbox_group(candidate_profile, :regions, options: Onboarding::CandidateProfile::REGIONS,
          label: "Preferred regions", grid_class: "grid-cols-2 sm:grid-cols-3", required: true) %>
  </div>

  <div>
    <%= field_label(form, :max_travel_time_minutes, text: "Maximum travel time (minutes)", candidate_profile: candidate_profile, required: true) %>
    <%= form.number_field :max_travel_time_minutes, min: 0, class: form_input_class(candidate_profile, :max_travel_time_minutes) %>
    <%= field_errors(candidate_profile, :max_travel_time_minutes) %>
  </div>

  <div>
    <%= field_label(form, :search_status, candidate_profile: candidate_profile, required: true) %>
    <%= form.select :search_status,
          Onboarding::CandidateProfile.search_statuses.keys.map { |key| [ key.humanize, key ] },
          { include_blank: true }, class: form_input_class(candidate_profile, :search_status) %>
    <%= field_errors(candidate_profile, :search_status) %>
  </div>

  <div class="sm:col-span-2">
    <%= checkbox_group(candidate_profile, :transport_types, options: Onboarding::CandidateProfile::TRANSPORT_TYPES,
          label: "Transport type", grid_class: "grid-cols-2 sm:grid-cols-4") %>
  </div>

  <div class="sm:col-span-2">
    <%= field_label(form, :reason_for_looking, candidate_profile: candidate_profile) %>
    <%= form.text_area :reason_for_looking, rows: 3, class: form_input_class(candidate_profile, :reason_for_looking) %>
    <%= field_errors(candidate_profile, :reason_for_looking) %>
  </div>
</div>
